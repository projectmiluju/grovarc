# ============================================
# Grovarc .gitignore
# ============================================

# ── 환경변수 ─────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
*.tfvars
*.tfvars.json

# ── Node / Next.js ───────────────────────────
node_modules/
.next/
.nuxt/
dist/
.pnpm-store/
.bun/
.turbo/
*.tsbuildinfo
.vercel/
.cache/

# ── Python / FastAPI ─────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
build/

# ── Kotlin / Java / Spring Boot ──────────────
*.jar
!apps/api/gradle/wrapper/gradle-wrapper.jar
*.war
*.class
.gradle/
gradle/
!apps/api/gradle/
apps/api/build/
out/
target/
*.ipr
*.iws

# ── AI / ML ──────────────────────────────────
# 모델 파일 (용량이 크므로 제외, Hugging Face Hub에 업로드)
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
*.gguf
# 학습 데이터 (민감 정보 포함 가능)
data/raw/
data/processed/
datasets/
# 학습 결과물
outputs/training/
runs/
wandb/
mlruns/

# ── Terraform ────────────────────────────────
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
terraform.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Kubernetes ───────────────────────────────
# 시크릿 파일은 절대 커밋 금지
*-secret.yaml
*-secret.yml
secrets/
kubeconfig
*.kubeconfig

# ── Docker ───────────────────────────────────
.docker/

# ── IDE ──────────────────────────────────────
.idea/
.vscode/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# ── OS ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── 로그 ─────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── 테스트 커버리지 ──────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Claude / AI 툴 ───────────────────────────
# .claude/ 폴더는 커밋 (commands 포함)
# 단, 민감한 컨텍스트 파일은 제외
.claude/cache/

# ── 기타 ─────────────────────────────────────
*.tmp
*.temp
*.bak
*.swp
*.orig
.turbo

# docs/devlog  ← 개발일지는 커밋 대상